# ===========================================
# Rent-A-Buddy™ — Environment Variables
# ===========================================

# PostgreSQL connection string (required)
# For self-hosted DB: postgresql://user:password@db:5432/rentabuddy
# For managed DB: use your provider's connection string
DATABASE_URL=postgresql://rentabuddy:changeme@db:5432/rentabuddy

# Individual PostgreSQL vars (used by docker-compose db service)
PGUSER=rentabuddy
PGPASSWORD=changeme
PGDATABASE=rentabuddy
PGHOST=db
PGPORT=5432

# Session secret — random string for signing cookies (required)
SESSION_SECRET=change-me-to-a-random-string

# Admin account credentials — seeded on first startup (required)
ADMIN_EMAIL=admin@rentabuddy.com
ADMIN_PASSWORD=YourSecurePassword123!

# Public URL of the deployed app — used in meta tags and emails (required for production)
APP_URL=https://yourdomain.com

# Server port (default: 5000)
PORT=5000
